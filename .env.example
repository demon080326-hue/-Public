# Public values are safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=news-images

# Server-only values. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used only by POST /api/ai-news/ingest. Generate a long random value locally.
AI_NEWS_INGEST_SECRET=
